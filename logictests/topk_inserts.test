# Coverage for TopK under insert sequences (mixed-order, growing past k,
# bulk insert displacing top-k).

# --- it_forwards: mixed-order inserts, ORDER BY DESC LIMIT 3 ---

statement ok
create table t_fwd (x int primary key, y int, z int)

statement ok
insert into t_fwd values (1,1,12)

query I nosort
select x from t_fwd where y = ? order by z desc limit 3
? = 1
----
1

statement ok
insert into t_fwd values (2,1,10)

query I nosort
select x from t_fwd where y = ? order by z desc limit 3
? = 1
----
1
2

statement ok
insert into t_fwd values (3,1,11)

query I nosort
select x from t_fwd where y = ? order by z desc limit 3
? = 1
----
1
3
2

statement ok
insert into t_fwd values (4,1,5)

query I nosort
select x from t_fwd where y = ? order by z desc limit 3
? = 1
----
1
3
2

statement ok
insert into t_fwd values (5,1,15)

query I nosort
select x from t_fwd where y = ? order by z desc limit 3
? = 1
----
5
1
3

# --- it_keeps_topk: state stays at k=3 even with more rows + duplicates ---

statement ok
create table t_keep (x int primary key, y int, z int)

statement ok
insert into t_keep values (1,1,12),(3,1,11),(4,1,5),(6,1,10),(7,1,10)

query I nosort
select x from t_keep where y = ? order by z desc, x asc limit 3
? = 1
----
1
3
6

statement ok
insert into t_keep values (5,1,15),(2,1,10)

query I nosort
select x from t_keep where y = ? order by z desc, x asc limit 3
? = 1
----
5
1
3

# --- truncation_drops_topk_without_negative: bulk insert displaces top-k ---

statement ok
create table t_trunc (x int primary key, y int, z int)

statement ok
insert into t_trunc values
  (1,1,100),(2,1,200),(3,1,300),(4,1,400),(5,1,500),(6,1,600)

query I nosort
select x from t_trunc where y = ? order by z desc limit 3
? = 1
----
6
5
4

statement ok
insert into t_trunc values
  (10,1,700),(11,1,701),(12,1,702),(13,1,703),
  (14,1,704),(15,1,705),(16,1,706)

query I nosort
select x from t_trunc where y = ? order by z desc limit 3
? = 1
----
16
15
14
