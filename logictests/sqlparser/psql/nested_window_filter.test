# Discriminator: outer __rn = 2 should give different value than __rn = 1.
query I rowsort
SELECT
    "INNER"."test_integer2" AS "t2"
FROM
    (SELECT
            "INNER"."test_integer2" AS "test_integer2",
            ROW_NUMBER() OVER(
                ORDER BY
                    "INNER"."test_integer2" ASC NULLS LAST
            ) AS "__rn"
        FROM
            (SELECT
                    "dt"."test_integer2" AS "test_integer2",
                    "dt"."rownum" AS "rownum",
                    ROW_NUMBER() OVER(
                        PARTITION BY "dt"."test_integer2"
                        ORDER BY
                            "dt"."rownum" ASC NULLS LAST
                    ) AS "__rn"
                FROM
                    "rea6496c_dt3" AS "dt"
            ) AS "INNER"
            INNER JOIN "rea6496c_dt" ON (
                "INNER"."test_integer2" = "rea6496c_dt"."test_integer"
            )
        WHERE
            ("INNER"."__rn" <= 1)
    ) AS "INNER"
    CROSS JOIN "rea6496c_s"
WHERE
    ("INNER"."__rn" = 2)
ORDER BY
    1 NULLS LAST;
----
10
10
