# Regression test for REA-6338: nested subqueries with ROW_NUMBER() AS __rn
# at each level. The outer WHERE __rn <= 1 was lost because
# column_id_for_column resolved the shadowed __rn to the wrong (inner,
# pass-through) column after predicate_pushup.
#
# These queries use explicit column lists instead of SELECT * because
# PostgreSQL allows duplicate column names in derived tables but ReadySet's
# implied_tables pass requires unique column names per table.

statement ok
CREATE TABLE rea6338 (id INT PRIMARY KEY, group_id INT, val INT);

statement ok
INSERT INTO rea6338 VALUES
  (1, 1, 10), (2, 1, 20), (3, 1, 30),
  (4, 2, 40), (5, 2, 50), (6, 2, 60),
  (7, 3, 70), (8, 3, 80), (9, 3, 90);

# Inner level: ROW_NUMBER per group, filter to top-1 per group -> 3 rows.
# Outer level: ROW_NUMBER over those 3, filter to top-1 overall -> 1 row.
query IIII
SELECT id, group_id, val, __rn FROM (
    SELECT id, group_id, val,
           ROW_NUMBER() OVER (ORDER BY val) AS __rn
    FROM (
        SELECT id, group_id, val FROM (
            SELECT id, group_id, val,
                   ROW_NUMBER() OVER (PARTITION BY group_id ORDER BY val) AS __rn
            FROM rea6338
        ) level0
        WHERE __rn <= 1
    ) level0_filtered
) level1
WHERE __rn <= 1;
----
1
1
10
1

# Outer __rn = 2: returns 1 row where outer __rn = 2.
# This discriminates between the two __rn columns — if they were confused,
# the filter would match the wrong column.
query IIII
SELECT id, group_id, val, __rn FROM (
    SELECT id, group_id, val,
           ROW_NUMBER() OVER (ORDER BY val) AS __rn
    FROM (
        SELECT id, group_id, val FROM (
            SELECT id, group_id, val,
                   ROW_NUMBER() OVER (PARTITION BY group_id ORDER BY val) AS __rn
            FROM rea6338
        ) level0
        WHERE __rn <= 1
    ) level0_filtered
) level1
WHERE __rn = 2;
----
4
2
40
2

# Same structure but with <= 2 at the outer level -> 2 rows.
query IIII rowsort
SELECT id, group_id, val, __rn FROM (
    SELECT id, group_id, val,
           ROW_NUMBER() OVER (ORDER BY val) AS __rn
    FROM (
        SELECT id, group_id, val FROM (
            SELECT id, group_id, val,
                   ROW_NUMBER() OVER (PARTITION BY group_id ORDER BY val) AS __rn
            FROM rea6338
        ) level0
        WHERE __rn <= 1
    ) level0_filtered
) level1
WHERE __rn <= 2;
----
1
1
10
1
4
2
40
2

# Verify that without the outer filter we get all 3 rows (one per group).
query IIII rowsort
SELECT id, group_id, val, __rn FROM (
    SELECT id, group_id, val,
           ROW_NUMBER() OVER (ORDER BY val) AS __rn
    FROM (
        SELECT id, group_id, val FROM (
            SELECT id, group_id, val,
                   ROW_NUMBER() OVER (PARTITION BY group_id ORDER BY val) AS __rn
            FROM rea6338
        ) level0
        WHERE __rn <= 1
    ) level0_filtered
) level1;
----
1
1
10
1
4
2
40
2
7
3
70
3
