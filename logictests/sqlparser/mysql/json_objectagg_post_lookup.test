# Test json_objectagg with WHERE IN,
# which triggers post-lookup aggregation.

statement ok
CREATE TABLE joa_pl (grp INT, k VARCHAR(255), v VARCHAR(255), PRIMARY KEY (grp, k));

statement ok
INSERT INTO joa_pl VALUES
  (1, 'a', 'alpha'),
  (1, 'b', 'bravo'),
  (2, 'c', 'charlie'),
  (2, 'd', 'delta'),
  (3, 'e', 'echo');

# json_objectagg with WHERE IN — post-lookup merges two groups
query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (1, 2);
----
{"a":"alpha","b":"bravo","c":"charlie","d":"delta"}

# Single group via WHERE IN — should still work
query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (3);
----
{"e":"echo"}

# All three groups
query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (1, 2, 3);
----
{"a":"alpha","b":"bravo","c":"charlie","d":"delta","e":"echo"}

# Verify deletes propagate correctly through post-lookup
statement ok
DELETE FROM joa_pl WHERE grp = 1 AND k = 'b';

query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (1, 2);
----
{"a":"alpha","c":"charlie","d":"delta"}

# Verify inserts propagate correctly through post-lookup
statement ok
INSERT INTO joa_pl VALUES (1, 'f', 'foxtrot');

query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (1, 2);
----
{"a":"alpha","c":"charlie","d":"delta","f":"foxtrot"}

# Duplicate key across groups — last writer wins (MySQL json_objectagg deduplicates)
statement ok
INSERT INTO joa_pl VALUES (2, 'a', 'overwritten');

query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (1, 2);
----
{"a":"overwritten","c":"charlie","d":"delta","f":"foxtrot"}

# Empty result from WHERE IN
query T nosort
SELECT json_objectagg(k, v) FROM joa_pl WHERE grp IN (999);
----
NULL
