# Regression tests for AVG/SUM precision on NUMERIC and INT types.
#
# REA-6199: Postgres AVG on NUMERIC/INT returned wrong number of digits.
#   - AVG used DEFAULT_NUMERIC (scale=0) for all non-float types, instead of
#     dynamically computing display scale (~16 sig digits).
#   - SUM on NUMERIC lost the input scale, using scale=0.
#
# These tests verify byte-for-byte match with upstream PostgreSQL.

# --- REA-6199: AVG on INT should return NUMERIC with ~16 significant digits ---

statement ok
CREATE TABLE t_avg_int (id INT PRIMARY KEY, val INT)

statement ok
INSERT INTO t_avg_int VALUES (1, 5), (2, 3)

# Postgres AVG(INT) returns numeric with 16 decimal places for small values
query R nosort
SELECT AVG(val) FROM t_avg_int
----
4.0000000000000000

# --- REA-6199: AVG on BIGINT should also return NUMERIC with ~16 sig digits ---

statement ok
CREATE TABLE t_avg_bigint (id INT PRIMARY KEY, val BIGINT)

statement ok
INSERT INTO t_avg_bigint VALUES (1, 5000000000), (2, 3000000000)

# Larger magnitude → fewer decimal places (dynamic scale algorithm)
query R nosort
SELECT AVG(val) FROM t_avg_bigint
----
4000000000.000000

# --- REA-6199: SUM on NUMERIC(10,2) should preserve input scale ---

statement ok
CREATE TABLE t_sum_num (id INT PRIMARY KEY, val NUMERIC(10,2))

statement ok
INSERT INTO t_sum_num VALUES (1, 3.50), (2, 3.30)

# SUM should preserve the NUMERIC scale of 2
query R nosort
SELECT SUM(val) FROM t_sum_num
----
6.80

# --- REA-6199: AVG on NUMERIC(10,2) should have appropriate display scale ---

statement ok
CREATE TABLE t_avg_num (id INT PRIMARY KEY, val NUMERIC(10,2))

statement ok
INSERT INTO t_avg_num VALUES (1, 5.50), (2, 3.30)

# Postgres AVG on NUMERIC uses dynamic scale (~16 significant digits)
query R nosort
SELECT AVG(val) FROM t_avg_num
----
4.4000000000000000

statement ok
DROP TABLE t_avg_int

statement ok
DROP TABLE t_avg_bigint

statement ok
DROP TABLE t_sum_num

statement ok
DROP TABLE t_avg_num
