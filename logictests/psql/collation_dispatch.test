# Per-column collation dispatch.
#
# A column declared `COLLATE "C"` must sort by raw byte order (matching
# Postgres's `C` / `POSIX` semantics), not by ICU root tertiary (which is
# Readyset's default for unqualified text columns).
#
# The data exercises a divergence: byte order interleaves uppercase and
# lowercase by ASCII codepoint, while ICU root tertiary sorts case-insensitive
# at the primary level and treats `-` as variable-weight.
#   byte order:        '-' (0x2D) < '0'..'9' (0x30..) < 'A'..'Z' (0x41..) < 'a'..'z' (0x61..)

statement ok
CREATE TABLE coll_c (
  id INT PRIMARY KEY,
  s  TEXT COLLATE "C"
)

statement ok
INSERT INTO coll_c VALUES
  (1, 'apple'),
  (2, 'Banana'),
  (3, 'apple-pie'),
  (4, 'applepie'),
  (5, 'BANANA-split'),
  (6, '-leading-dash'),
  (7, 'Apple')

query IT nosort
SELECT id, s FROM coll_c ORDER BY s
----
6
-leading-dash
7
Apple
5
BANANA-split
2
Banana
1
apple
3
apple-pie
4
applepie
