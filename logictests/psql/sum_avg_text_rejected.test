# REA-6277: SUM on text columns is not valid in PostgreSQL
#
# Unlike MySQL (which coerces text → numeric), PostgreSQL rejects SUM
# on text columns at query planning time. Verify Readyset matches this
# behavior by rejecting the query.
#
# Note: AVG on text is also invalid in PostgreSQL, but Readyset does
# not currently validate the input type for AVG (only for SUM). This
# is a known gap tracked separately.

statement ok
CREATE TABLE t_text_agg_psql (grp INT, val TEXT);

statement ok
INSERT INTO t_text_agg_psql (grp, val) VALUES (1, '5'), (1, '3');

statement error: Cannot sum over type
SELECT SUM(val) FROM t_text_agg_psql;
