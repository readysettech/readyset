# Coverage for TopK under update/insert/delete churn against a partial
# (parameterized) group, including transient drops below k mid-batch
# and groups with rows that exceed the operator's `k + buffered` cap.

statement ok
create table t (id int primary key, val int, grp int)

statement ok
insert into t values
  (1, 10, 1), (2, 20, 1), (3, 30, 1), (4, 40, 1), (5, 50, 1),
  (6, 15, 1), (7, 25, 1)

# --- Updates that push a top-k row out of top-k ---

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 1
----
1
6
2

statement ok
update t set val = 100 where id = 2

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 1
----
1
6
7

statement ok
update t set val = 200 where id = 1

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 1
----
6
7
3

# --- Update that brings a non-top-k row into top-k via smaller value ---

statement ok
update t set val = 5 where id = 4

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 1
----
4
6
7

# --- Delete from top-k, refill from buffer/parent ---

statement ok
delete from t where id = 6

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 1
----
4
7
3

# --- Inserts that should join top-k ---

statement ok
insert into t values (8, 1, 1), (9, 2, 1)

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 1
----
8
9
4

# --- Group with rows exceeding k + buffered (default 6 for k=3) so
#     the operator has hidden parent rows. Then delete top-k rows and
#     verify backfill promotes the actual next-best (not stale buffer
#     entries). ---

statement ok
insert into t values
  (10, 100, 2), (11, 200, 2), (12, 300, 2), (13, 400, 2),
  (14, 500, 2), (15, 600, 2), (16, 700, 2), (17, 800, 2),
  (18, 900, 2)

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 2
----
10
11
12

# Worse-than-worst insert should not displace anything in top-3.
statement ok
insert into t values (19, 1000, 2)

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 2
----
10
11
12

# Delete top-3. Operator must promote rows beyond its initial buffer,
# fetched from the parent.
statement ok
delete from t where id = 10

statement ok
delete from t where id = 11

statement ok
delete from t where id = 12

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 2
----
13
14
15

# Update a buffer-zone row down into top-3.
statement ok
update t set val = 50 where id = 18

query I nosort
select id from t where grp = ? order by val asc limit 3
? = 2
----
18
13
14
