# DISTINCT with range parameters (post-lookup)

statement ok
CREATE TABLE t_dpl (
  id INT PRIMARY KEY,
  category INT,
  value INT
)

statement ok
INSERT INTO t_dpl (id, category, value) VALUES
  (1,  1, 10),
  (2,  1, 20),
  (3,  1, 30),
  (4,  2, 10),
  (5,  2, 20),
  (6,  2, 20),
  (7,  3, 40),
  (8,  3, 40),
  (9,  3, 40),
  (10, 4, 50)

# DISTINCT without aggregates, range param (pure dedup)

query I rowsort
SELECT DISTINCT value FROM t_dpl WHERE id > ?
? = 2
----
10
20
30
40
50

query I rowsort
SELECT DISTINCT category FROM t_dpl WHERE id > ?
? = 2
----
1
2
3
4

# Multi-column DISTINCT with range param
# id > 4 gives: (2,20),(2,20),(3,40),(3,40),(3,40),(4,50)
# DISTINCT collapses to: (2,20),(3,40),(4,50)
query II rowsort
SELECT DISTINCT category, value FROM t_dpl WHERE id > ?
? = 4
----
2
20
3
40
4
50

# DISTINCT + aggregate, no GROUP BY, range param
# Single result row — DISTINCT is a no-op here.
# id > 2 → 8 rows, values: 30,10,20,20,40,40,40,50

query I nosort
SELECT DISTINCT count(value) FROM t_dpl WHERE id > ?
? = 2
----
8

query I nosort
SELECT DISTINCT sum(value) FROM t_dpl WHERE id > ?
? = 2
----
250

query I nosort
SELECT DISTINCT max(value) FROM t_dpl WHERE id > ?
? = 2
----
50

query I nosort
SELECT DISTINCT min(value) FROM t_dpl WHERE id > ?
? = 2
----
10

# DISTINCT + aggregate + GROUP BY + range param
# id > 2 grouped by category:
#   cat 1: (30)        → count=1, sum=30
#   cat 2: (10,20,20)  → count=3, sum=50
#   cat 3: (40,40,40)  → count=3, sum=120
#   cat 4: (50)        → count=1, sum=50
# DISTINCT count: {1,3,3,1} → {1,3}
# DISTINCT sum:   {30,50,120,50} → {30,50,120}

query I rowsort
SELECT DISTINCT count(value) FROM t_dpl WHERE id > ? GROUP BY category
? = 2
----
1
3

query I rowsort
SELECT DISTINCT sum(value) FROM t_dpl WHERE id > ? GROUP BY category
? = 2
----
120
30
50

# Non-DISTINCT equivalent for comparison

query I rowsort
SELECT count(value) FROM t_dpl WHERE id > ? GROUP BY category
? = 2
----
1
1
3
3

# After DELETE, verify DISTINCT + range param still works
# Remove cat=3 (ids 7,8,9). id > 2 now gives:
#   cat 1: (30)        → count=1, sum=30
#   cat 2: (10,20,20)  → count=3, sum=50
#   cat 4: (50)        → count=1, sum=50

statement ok
DELETE FROM t_dpl WHERE id = 7

statement ok
DELETE FROM t_dpl WHERE id = 8

statement ok
DELETE FROM t_dpl WHERE id = 9

# Pure dedup after delete
query I rowsort
SELECT DISTINCT value FROM t_dpl WHERE id > ?
? = 2
----
10
20
30
50

# Ungrouped aggregate after delete
query I nosort
SELECT DISTINCT count(value) FROM t_dpl WHERE id > ?
? = 2
----
5

# Grouped aggregates after delete
# DISTINCT count: {1,3,1} → {1,3}
query I rowsort
SELECT DISTINCT count(value) FROM t_dpl WHERE id > ? GROUP BY category
? = 2
----
1
3

# DISTINCT sum: {30,50,50} → {30,50}
query I rowsort
SELECT DISTINCT sum(value) FROM t_dpl WHERE id > ? GROUP BY category
? = 2
----
30
50

# DISTINCT + ORDER BY + LIMIT

query I nosort
SELECT DISTINCT value FROM t_dpl WHERE id > ? ORDER BY value
? = 2
----
10
20
30
50

query I nosort
SELECT DISTINCT value FROM t_dpl WHERE id > ? ORDER BY value LIMIT 3
? = 2
----
10
20
30

query I nosort
SELECT DISTINCT count(value) AS cnt FROM t_dpl WHERE id > ? GROUP BY category ORDER BY cnt LIMIT 1
? = 2
----
1
